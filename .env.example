# Copy to .env and fill in real values. .env is gitignored; never commit secrets.
# (development-principles 6.2: this example holds key names and safe notes only.)

# --- Philips WiZ bulb (local UDP, no cloud account or token) ---------------
# JSON object mapping an internal device id to the bulb's address. Three forms:
#   "10.26.34.165"                 IP only    - direct, no discovery
#   "9877d5cffaf8"                 MAC only   - found by broadcast discovery
#   "9877d5cffaf8@10.26.34.165"    MAC@IP     - RECOMMENDED
# MAC@IP sends straight to the IP (fast, no discovery) and falls back to
# discovering by MAC only if that IP stops answering, so it survives DHCP changes.
# Prefer it: some networks/adapters do not deliver broadcasts, which makes
# MAC-only discovery fail even though the bulb is reachable by IP (measured).
WIZ_DEVICE_TARGETS={}

# Optional (default 3.0). UDP round trip on a LAN is ~15-50ms.
# WIZ_TIMEOUT_S=3.0

# --- SmartThings cloud bulb (alternative path; unused when WiZ is configured) -
# SmartThings Personal Access Token.
# Create one at https://account.smartthings.com/tokens with device read + control scopes.
SMARTTHINGS_TOKEN=

# JSON object mapping an internal device id to its SmartThings device UUID.
# Example: {"room.bulb": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"}
# List your devices' UUIDs with: GET https://api.smartthings.com/v1/devices
SMARTTHINGS_DEVICE_TARGETS={}

# Optional overrides (defaults shown).
# SMARTTHINGS_BASE_URL=https://api.smartthings.com/v1
# SMARTTHINGS_TIMEOUT_S=5.0
