# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/

# Node
node_modules/
npm-debug.log*
dist/
build/

# Env / secrets
.env
.env.local

# Logs
*.log

# Claude Code local settings
.claude/

# Local model binaries and evaluation artifacts
models/*.task
models/*.onnx
models/*.pt
# 예외: 정적 자세 분류기는 10KB로 작고 데모에 바로 필요해 저장소에 포함한다
# (동적 제스처 TCN 가중치는 크므로 여전히 제외 — models/README.md의 재현 절차 참조).
!models/hand_pose_classifier.pt
data/raw/
data/traces/
data/calibration/
data/evaluation/gaze_samples.json
artifacts/

# Training pipeline (training/) — offline landmark cache, TensorBoard runs
training/cache/
training/runs/

# 실험용 체크포인트(별도 경로로 학습한 A/B 결과물)
training/experiments/

# 동작 클립(.npz)은 어디에 두든 커밋하지 않는다 — cache 밖 백업 폴더(잘못 녹화분
# 격리 등) 포함. training/cache/가 이미 캐시를 덮지만, 백업/임시 경로도 함께 막는다.
training/**/*.npz
